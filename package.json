{
    "$schema": "https://json.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "scripts": {
        "build": "npm run copy:datatables && npm run copy:intl-tel-input && vite build",
        "dev": "vite",
        "copy:flatpickr": "node -e \"const fs=require('fs');const p='node_modules/flatpickr/dist/';fs.copyFileSync(p+'flatpickr.min.js','public/js/flatpickr.min.js');fs.copyFileSync(p+'flatpickr.min.css','public/css/flatpickr.min.css')\"",
        "copy:datatables": "node scripts/copy-datatables.cjs",
        "copy:intl-tel-input": "node scripts/copy-intl-tel-input.cjs",
        "copy:inputmask": "node -e \"const fs=require('fs');const p='node_modules/inputmask/dist/';fs.copyFileSync(p+'inputmask.min.js','public/js/inputmask.min.js');\""
    },
    "devDependencies": {
        "@tailwindcss/forms": "^0.5.2",
        "@tailwindcss/vite": "^4.0.0",
        "alpinejs": "^3.4.2",
        "autoprefixer": "^10.4.2",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "datatables.net": "^1.13.11",
        "datatables.net-bs5": "^1.13.11",
        "datatables.net-buttons": "^2.4.3",
        "datatables.net-buttons-bs5": "^2.4.3",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "tailwindcss": "^3.1.0",
        "vite": "^7.0.4"
    },
    "dependencies": {
        "@fullcalendar/core": "^6.1.19",
        "@fullcalendar/daygrid": "^6.1.19",
        "@fullcalendar/interaction": "^6.1.19",
        "@fullcalendar/list": "^6.1.19",
        "@fullcalendar/timegrid": "^6.1.19",
        "flatpickr": "^4.6.13",
        "inputmask": "^5.0.9",
        "intl-tel-input": "^24.8.2",
        "laravel-echo": "^2.2.4",
        "pusher-js": "^8.4.0",
        "signature_pad": "^5.1.1"
    }
}
